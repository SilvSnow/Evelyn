---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import cover from '../assets/cover.jpg';

// Eagerly import every photo so Astro can optimize them at build time.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/pottery/*.{jpeg,jpg,JPG,JPEG,png,PNG}',
  { eager: true }
);

// Turn a filename like "17-carving-detail-on-pot.jpg" into alt text:
// "Carving detail on pot" (drops the order prefix, the -bw suffix, and ext).
const toAlt = (path: string) => {
  const base = path.split('/').pop()!.replace(/\.[^.]+$/, '');
  const words = base
    .replace(/^\d+-/, '')
    .replace(/-bw$/, '')
    .replace(/-/g, ' ')
    .trim();
  return words.charAt(0).toUpperCase() + words.slice(1);
};

const photos = Object.entries(modules)
  .map(([path, mod]) => ({ path, img: mod.default, alt: toAlt(path) }))
  .sort((a, b) => a.path.localeCompare(b.path));
---

<BaseLayout title="Evelyn · Handmade Pottery">
  <section class="hero-banner">
    <Image
      class="hero-banner__img"
      src={cover}
      alt="Evelyn glazing a vase in her studio"
      widths={[720, 1080, 1600, 2200]}
      sizes="100vw"
      loading="eager"
    />
    <div class="hero-banner__overlay">
      <h1>Handmade Pottery</h1>
      <p>Wheel-thrown and hand-built pieces, glazed and fired one at a time.</p>
    </div>
  </section>

  <div class="container">
    <div class="gallery">
      {photos.map(({ img, alt }, i) => (
        <figure>
          <Image
            src={img}
            alt={alt}
            widths={[320, 640, 960]}
            sizes="(max-width: 640px) 100vw, (max-width: 1080px) 50vw, 340px"
            loading={i < 6 ? 'eager' : 'lazy'}
          />
        </figure>
      ))}
    </div>
  </div>
</BaseLayout>
