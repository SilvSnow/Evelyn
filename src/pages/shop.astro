---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Shop · Evelyn Pottery"
  description="Handmade pottery for sale — coming soon."
>
  <section class="page container">
    <h1>Shop</h1>
    <p class="lead">A small shop is in the works.</p>
    <div class="prose">
      <p>
        I'm getting ready to offer a limited number of pieces for sale here — each
        one-of-a-kind, wheel-thrown or hand-built, and glazed by hand. Because they're
        made one at a time, quantities will always be small.
      </p>
      <p>
        Want first pick when the shop opens? <a href="/contact">Send me a note</a> and
        I'll let you know when new pieces go up.
      </p>
      <p>
        In the meantime, browse the <a href="/">gallery</a> to see the kind of work
        you can expect.
      </p>
    </div>
  </section>
</BaseLayout>
